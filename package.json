{
  "name": "fluent-html",
  "version": "5.9.0",
  "description": "Fluent, type-safe HTML builder for TypeScript. Chainable styling API, first-class HTMX support with full autocomplete, automatic XSS protection. Zero dependencies, SSR-ready.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./core": {
      "types": "./dist/src/core/index.d.ts",
      "default": "./dist/src/core/index.js"
    },
    "./elements": {
      "types": "./dist/src/elements/index.d.ts",
      "default": "./dist/src/elements/index.js"
    },
    "./control": {
      "types": "./dist/src/control/index.d.ts",
      "default": "./dist/src/control/index.js"
    },
    "./render": {
      "types": "./dist/src/render/index.d.ts",
      "default": "./dist/src/render/index.js"
    },
    "./fold": {
      "types": "./dist/src/fold/index.d.ts",
      "default": "./dist/src/fold/index.js"
    },
    "./ids": {
      "types": "./dist/src/ids.d.ts",
      "default": "./dist/src/ids.js"
    },
    "./routes": {
      "types": "./dist/src/routes.d.ts",
      "default": "./dist/src/routes.js"
    },
    "./htmx": {
      "types": "./dist/src/htmx.d.ts",
      "default": "./dist/src/htmx.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test dist/test/test.js dist/test/patterns.js dist/test/routes.js dist/test/ids.js dist/test/fold.js dist/test/fluent-styling-v2.js dist/test/type-safety.js dist/test/escape.js dist/test/guards.js dist/test/elements.js dist/test/overlay.js dist/test/fuzz.js",
    "test:coverage": "npm run build && c8 --lines 95 --branches 90 node --test dist/test/test.js dist/test/patterns.js dist/test/routes.js dist/test/ids.js dist/test/fold.js dist/test/fluent-styling-v2.js dist/test/type-safety.js dist/test/escape.js dist/test/guards.js dist/test/elements.js dist/test/overlay.js dist/test/fuzz.js",
    "bench": "npm run build && node dist/bench/render.js",
    "bench:mem": "npm run build && node --expose-gc dist/bench/render.js",
    "docs": "typedoc",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "prepack": "npm run build && npm test",
    "prepublishOnly": "npm pack --dry-run"
  },
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JT-Digital-d-o-o/fluent-html.git"
  },
  "keywords": [
    "html-builder",
    "typescript",
    "fluent-api",
    "type-safe",
    "htmx",
    "tailwind",
    "server-side-rendering",
    "ssr",
    "html",
    "xss-protection",
    "zero-dependencies",
    "functional-html",
    "chainable",
    "jsx-alternative"
  ],
  "author": "JT Digital d.o.o.",
  "contributors": [
    "Toni K. Turk"
  ],
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/JT-Digital-d-o-o/fluent-html/issues"
  },
  "homepage": "https://github.com/JT-Digital-d-o-o/fluent-html#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "c8": "^11.0.0",
    "eslint-plugin-fluent-html": "file:../fluent-html-eslint-plugin",
    "typedoc": "^0.28.17",
    "typescript": "^5.0.0"
  }
}
